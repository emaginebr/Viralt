# ============================================
# Viralt - Environment Variables (Development)
# ============================================
# Copy this file to .env and fill in the values.

# Database
DB_NAME=viralt
DB_USER=postgres
DB_PASSWORD=YOUR_PASSWORD
DB_PORT=5432

# Backend API
API_PORT=5000
ASPNETCORE_ENVIRONMENT=Docker

# NAuth
NAUTH_API_URL=http://nauth-api:80
NAUTH_BUCKET_NAME=viralt
NAUTH_JWT_SECRET=YOUR_JWT_SECRET

# zTools
ZTOOLS_API_URL=http://ztools-api:80

# BazzucaMedia
BazzucaMedia__ApiKey=YOUR_BAZZUCA_KEY

# Recaptcha
Recaptcha__SiteKey=YOUR_RECAPTCHA_SITE_KEY
Recaptcha__SecretKey=YOUR_RECAPTCHA_SECRET_KEY

# Frontend
APP_PORT=3000
REACT_APP_API_URL=http://localhost:5000
