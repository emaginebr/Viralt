# ============================================
# Viralt - Environment Variables (Production)
# ============================================
# Copy this file to .env.prod and fill in the values.
# Only secrets and environment-specific values.

# Database
DB_NAME=viralt
DB_USER=postgres
DB_PASSWORD=YOUR_SECURE_PRODUCTION_PASSWORD
ConnectionStrings__ViraltContext=Host=viralt-db;Port=5432;Database=viralt;Username=postgres;Password=YOUR_SECURE_PRODUCTION_PASSWORD

# ASP.NET
ASPNETCORE_ENVIRONMENT=Production

# NAuth
NAUTH_API_URL=http://nauth-api:80
NAUTH_BUCKET_NAME=viralt
NAUTH_JWT_SECRET=YOUR_PRODUCTION_JWT_SECRET
NAuth__ApiURL=http://nauth-api:80
NAuth__BucketName=viralt
NAuth__JwtSecret=YOUR_PRODUCTION_JWT_SECRET

# zTools
ZTOOLS_API_URL=http://ztools-api:80
zTools__ApiURL=http://ztools-api:80

# BazzucaMedia
BazzucaMedia__ApiKey=YOUR_PRODUCTION_BAZZUCA_KEY

# Recaptcha
Recaptcha__SiteKey=YOUR_PRODUCTION_RECAPTCHA_SITE_KEY
Recaptcha__SecretKey=YOUR_PRODUCTION_RECAPTCHA_SECRET_KEY

# Frontend
REACT_APP_API_URL=https://your-production-domain.com
